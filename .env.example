# Flask app
SECRET_KEY=
FLASK_DEBUG=True
FLASK_HOST=127.0.0.1
FLASK_PORT=5001
AUTO_INSTALL_PLAYWRIGHT_CHROMIUM=true

# Data API
CRICKET_DATA_API_KEY=

# Market integrations (Wave 2 read-path readiness)
# Keep these local only; never commit real credentials.
POLYMARKET_ENABLED=false
POLYMARKET_API_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Wave 5 Phase 6a: write-path. Set after running scripts/bootstrap_polymarket_wallet.py.
# POLYGON_PRIVATE_KEY is the EOA private key signing CLOB orders (32-byte hex).
# POLYGON_FUNDER_ADDR is required only for proxy-wallet (signature_type=1) or
# Gnosis Safe (signature_type=2) setups; leave blank for EOA (signature_type=0).
POLYGON_PRIVATE_KEY=
POLYGON_FUNDER_ADDR=
POLYMARKET_SIGNATURE_TYPE=0

# Wave 5 Phase 6c: live betting risk gate.
# Mode defaults to OFF — must be explicitly toggled via the UI before any bet
# can be placed. Caps enforced server-side; UI can only display them.
# Recommended starting envelope: $200 deposit / $25 per bet / $50 per day.
BETTING_MODE=OFF
BETTING_MAX_DEPOSIT=200
BETTING_MAX_PER_BET=25
BETTING_MAX_PER_DAY=50
BETTING_MAX_LOSS_PER_DAY=30
BETTING_AUTO_MIN_EDGE=5.0
BETTING_AUTO_MARKETS=moneyline
BETTING_KILL_SWITCH=0
BETTING_SCALE_MIN_BETS=50
BETTING_SCALE_MAX_BRIER_DRIFT=0.02

# Betfair — Indefinitely deferred (Polymarket pivot in Wave 5 supersedes).
# Code in src/integrations/betfair/ remains in repo for optionality but
# is no longer wired to any active Flask routes. Leave these blank unless
# you intend to resurrect Betfair integration.
BETFAIR_ENABLED=false
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_SESSION_TOKEN=
BETFAIR_CERT_FILE=
BETFAIR_KEY_FILE=
BETFAIR_SSO_BASE_URL=https://identitysso.betfair.com
BETFAIR_LOGIN_PATH=/api/login
BETFAIR_CERT_LOGIN_PATH=/api/certlogin
BETFAIR_KEEP_ALIVE_PATH=/api/keepAlive
BETFAIR_BETTING_API_BASE_URL=https://api.betfair.com/exchange/betting
